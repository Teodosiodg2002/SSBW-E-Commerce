{% extends "base.njk" %}

{% block title %}Iniciar sesión – Tienda Prado{% endblock %}
{% block description %}Accede a tu cuenta de la Tienda del Museo del Prado{% endblock %}

{% block content %}
<div class="row justify-content-center mt-5">
  <div class="col-sm-10 col-md-7 col-lg-5">

    <h1 class="section-title mb-1">Mi cuenta</h1>
    <p class="text-center text-muted mb-4" style="font-size:0.9rem;">Introduce tus datos para acceder.</p>

    {% if error %}
    <div class="alert alert-danger text-center py-2" style="font-size:0.88rem; border-radius:0;">
      <i class="bi bi-exclamation-circle me-1"></i>
      Credenciales incorrectas. Por favor, inténtalo de nuevo.
    </div>
    {% endif %}

    <form action="/login" method="POST" class="mt-3">
      <div class="mb-3">
        <label for="email" class="form-label" style="font-size:0.82rem; letter-spacing:0.08em; text-transform:uppercase;">Correo electrónico</label>
        <input type="email" id="email" name="email" class="form-control" style="border-radius:0;"
               required autofocus placeholder="tu@email.com">
      </div>
      <div class="mb-4">
        <label for="contraseña" class="form-label" style="font-size:0.82rem; letter-spacing:0.08em; text-transform:uppercase;">Contraseña</label>
        <input type="password" id="contraseña" name="contraseña" class="form-control" style="border-radius:0;"
               required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-add-cart w-100" id="login-btn">
        Iniciar sesión
      </button>
    </form>

    <p class="text-center mt-4" style="font-size:0.82rem; color:#aaa;">
      © Museo Nacional del Prado
    </p>
  </div>
</div>
{% endblock %}
