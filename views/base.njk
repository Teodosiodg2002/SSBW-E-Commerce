<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Tienda Prado{% endblock %}</title>
  <meta name="description" content="{% block description %}La tienda oficial del Museo del Prado{% endblock %}">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Georgia', serif; color: #333; background: #fff; }
    .top-bar { font-size: 0.75rem; letter-spacing: 0.08em; border-bottom: 1px solid #e0e0e0; padding: 6px 0; }
    .top-bar a { color: #555; text-decoration: none; }
    .top-bar a:hover { color: #000; }
    .site-header { border-bottom: 1px solid #e0e0e0; padding: 18px 0 10px; }
    .site-logo { font-size: 1.9rem; font-weight: 700; letter-spacing: 0.18em; color: #000; text-decoration: none; }
    .site-logo:hover { color: #333; }
    .header-icons a { color: #555; font-size: 1.1rem; margin-left: 12px; text-decoration: none; position: relative; }
    .header-icons a:hover { color: #000; }
    .lang-switcher { font-size: 0.8rem; color: #555; margin-left: 14px; }
    .cart-badge {
      position: absolute; top: -7px; right: -9px;
      background: #444; color: #fff;
      border-radius: 50%; font-size: 0.6rem;
      width: 17px; height: 17px;
      display: flex; align-items: center; justify-content: center;
      font-family: sans-serif; font-weight: 700;
    }
    .search-form .form-control { border-radius: 0; border: 1px solid #ccc; font-size: 0.85rem; padding: 5px 12px; background: #f9f9f9; }
    .search-form .btn { border-radius: 0; border: 1px solid #ccc; border-left: none; background: #f9f9f9; color: #555; }
    .search-form .btn:hover { background: #eee; }
    .main-nav { border-bottom: 1px solid #e0e0e0; font-size: 0.78rem; letter-spacing: 0.1em; }
    .main-nav .nav-link { color: #555; padding: 10px 14px; text-transform: uppercase; }
    .main-nav .nav-link:hover, .main-nav .nav-link.active { color: #000; font-weight: 700; }
    .section-title { font-size: 1.5rem; letter-spacing: 0.2em; text-align: center; margin: 40px 0 30px; color: #222; text-transform: uppercase; }
    .product-card { border: none; background: transparent; transition: transform 0.2s; }
    .product-card:hover { transform: translateY(-3px); }
    .product-card .card-img-wrap { background: #f7f7f7; border: 1px solid #ebebeb; display: flex; align-items: center; justify-content: center; padding: 16px; height: 230px; overflow: hidden; }
    .product-card img { max-height: 200px; max-width: 100%; object-fit: contain; }
    .product-card .card-title { font-size: 0.9rem; color: #333; margin-top: 12px; text-align: center; line-height: 1.4; }
    .product-card .card-price { font-size: 0.95rem; color: #333; text-align: center; margin-top: 4px; }
    .search-results-info { font-size: 0.88rem; color: #666; margin-bottom: 20px; }
    .detail-img-wrap { background: #f7f7f7; border: 1px solid #ebebeb; display: flex; align-items: center; justify-content: center; padding: 24px; min-height: 350px; }
    .detail-img-wrap img { max-width: 100%; max-height: 400px; object-fit: contain; }
    .detail-title { font-size: 1.6rem; font-weight: 600; margin-bottom: 16px; color: #222; }
    .detail-description { font-size: 0.95rem; color: #555; line-height: 1.7; white-space: pre-line; }
    .detail-price { font-size: 1.25rem; font-weight: 600; margin: 20px 0; color: #333; }
    .btn-add-cart { background-color: #666; color: #fff; border: none; padding: 10px 28px; letter-spacing: 0.1em; font-size: 0.85rem; border-radius: 0; text-transform: uppercase; }
    .btn-add-cart:hover { background-color: #444; color: #fff; }
    .qty-input { width: 70px; border-radius: 0; border-color: #ccc; text-align:center; }

    /* Carrito off-canvas (desde la derecha) */
    .offcanvas-cart { width: 380px !important; }
    .offcanvas-cart .offcanvas-header { border-bottom: 1px solid #eee; }
    .cart-item { display: flex; align-items: center; gap: 12px; padding: 14px 0; border-bottom: 1px solid #f0f0f0; }
    .cart-item img { width: 64px; height: 64px; object-fit: contain; background: #f7f7f7; border: 1px solid #eee; padding: 4px; flex-shrink:0; }
    .cart-item-name { font-size: 0.88rem; line-height: 1.3; color: #333; }
    .cart-item-price { font-size: 0.85rem; color: #555; margin-top: 4px; }
    .cart-totals { border-top: 1px solid #ddd; padding-top: 14px; margin-top: 14px; font-size: 0.9rem; }
    .cart-totals .total-row { display: flex; justify-content: space-between; margin-bottom: 6px; color: #555; }
    .cart-totals .total-row.grand { font-weight: 700; font-size: 1rem; color: #222; margin-top: 8px; border-top: 1px solid #eee; padding-top: 10px; }
    .btn-checkout { width: 100%; padding: 13px; background: #555; color: #fff; border: none; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.82rem; border-radius: 0; margin-top: 14px; }
    .btn-checkout:hover { background: #333; }
    .btn-see-cart { width: 100%; padding: 10px; background: #fff; color: #555; border: 1px solid #ccc; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.82rem; border-radius: 0; margin-top: 8px; }
    .btn-see-cart:hover { background: #f5f5f5; }

    footer { border-top: 1px solid #e0e0e0; margin-top: 60px; padding: 30px 0; font-size: 0.8rem; color: #888; }
  </style>
</head>
<body>

  {# Barra superior #}
  <div class="top-bar">
    <div class="container d-flex justify-content-between">
      <a href="https://www.museodelprado.es" target="_blank" rel="noreferrer">MUSEO DEL PRADO</a>
      <a href="https://www.imagebankmuseodelprado.com/" target="_blank" rel="noreferrer">IMAGE BANK</a>
    </div>
  </div>

  {# Header principal #}
  <header class="site-header">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-3"></div>
        <div class="col-md-6 text-center">
          <a href="/" class="site-logo">TIENDA PRADO</a>
        </div>
        <div class="col-md-3 d-flex align-items-center justify-content-end">
          <form class="search-form d-flex" action="/buscar" method="get">
            <input class="form-control" type="search" name="busqueda" placeholder="Buscar..." value="{{ busqueda or '' }}" id="search-input">
            <button class="btn" type="submit"><i class="bi bi-search"></i></button>
          </form>
          <div class="header-icons d-none d-md-flex align-items-center ms-2">
            {# Icono de cuenta: siempre apunta a /mi-cuenta (que redirige a /login si no hay sesión) #}
            <a href="/mi-cuenta" title="Ver mi cuenta de cliente" id="account-icon">
              <i class="bi bi-person{% if usuario %}-fill{% endif %}"></i>
            </a>
            {# Icono de carrito con badge de unidades #}
            <a href="#" title="Cesta" data-bs-toggle="offcanvas" data-bs-target="#cartDrawer" id="cart-icon" aria-controls="cartDrawer">
              <i class="bi bi-bag"></i>
              {% if total_carrito > 0 %}
                <span class="cart-badge">{{ total_carrito }}</span>
              {% endif %}
            </a>
          </div>
          <span class="lang-switcher">ES | EN</span>
        </div>
      </div>
    </div>
  </header>

  {# Navegación principal #}
  <nav class="main-nav">
    <div class="container">
      <ul class="nav d-flex flex-wrap">
        <li class="nav-item"><a class="nav-link" href="#">Libros</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Exposiciones</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Colaboraciones</a></li>
        <li class="nav-item"><a class="nav-link active" href="/">Impresiones</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Hogar</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Papelería</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Textil y Complementos</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Outlet</a></li>
      </ul>
    </div>
  </nav>

  {# Contenido de cada página #}
  <main class="container mt-4 mb-5">
    {% block content %}{% endblock %}
  </main>

  <footer>
    <div class="container text-center">
      <p>© Museo Nacional del Prado · Calle Ruiz de Alarcón 23, 28014 Madrid</p>
    </div>
  </footer>

  {# ═══ Drawer del carrito (off-canvas derecha) ═══ #}
  <div class="offcanvas offcanvas-end offcanvas-cart" tabindex="-1" id="cartDrawer" aria-labelledby="cartDrawerLabel">
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="cartDrawerLabel">Cesta</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column" id="cart-container">
      {# Se rellena dinámicamente con JS #}
      <div class="text-center py-5 loading-spinner">
        <div class="spinner-border text-secondary" role="status">
          <span class="visually-hidden">Cargando...</span>
        </div>
      </div>
    </div>
  </div>

  {# Template para cada ítem del carrito #}
  <template id="cart-item-template">
    <div class="cart-item" data-id="">
      <img src="" alt="" class="item-img">
      <div class="flex-grow-1">
        <div class="cart-item-name item-title"></div>
        <div class="cart-item-price"><span class="item-qty"></span> x <span class="item-price"></span> €</div>
      </div>
      <button class="btn p-0 border-0 btn-remove-item" style="color:#aaa; font-size:1.1rem;">
        <i class="bi bi-trash"></i>
      </button>
    </div>
  </template>

  {# Template para el resumen del carrito #}
  <template id="cart-summary-template">
    <div class="flex-grow-1 overflow-auto" id="cart-items-list">
      <!-- Los ítems se insertan aquí -->
    </div>
    <div class="cart-totals mt-auto" id="cart-totals">
      <div class="total-row"><span id="summary-items-count"></span><span><span id="summary-subtotal"></span> €</span></div>
      <div class="total-row"><span>Envío</span><span>Gratis</span></div>
      <div class="total-row grand"><span>Total</span><span><span id="summary-total"></span> €</span></div>
    </div>
    <button class="btn-checkout">Finalizar pedido</button>
    <a href="#" class="btn-see-cart">Ver Cesta</a>
  </template>

  {# Template para carrito vacío #}
  <template id="cart-empty-template">
    <div class="text-center text-muted py-5">
      <i class="bi bi-bag" style="font-size:2.5rem; opacity:0.3;"></i>
      <p class="mt-3">Tu cesta está vacía.</p>
    </div>
  </template>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    /**
     * Gestión del Carrito vía DOM y AJAX
     */
    const cartDrawer = document.getElementById('cartDrawer');
    const cartContainer = document.getElementById('cart-container');
    const cartBadge = document.querySelector('.cart-badge');
    const cartIconLink = document.getElementById('cart-icon');

    // Cargar el carrito cuando se abre el offcanvas
    cartDrawer.addEventListener('show.bs.offcanvas', () => {
      renderCart();
    });

    /**
     * Obtiene los datos de la API y renderiza el contenido
     */
    async function renderCart() {
      try {
        const response = await fetch('/api/carrito');
        const data = await response.json();
        
        cartContainer.innerHTML = ''; // Limpiar el contenedor (quitar spinner)

        if (data.productos.length === 0) {
          const template = document.getElementById('cart-empty-template');
          cartContainer.appendChild(template.content.cloneNode(true));
          updateBadge(0);
        } else {
          const summaryTemplate = document.getElementById('cart-summary-template');
          const summaryClone = summaryTemplate.content.cloneNode(true);
          
          const list = summaryClone.getElementById('cart-items-list');
          const itemTemplate = document.getElementById('cart-item-template');

          data.productos.forEach(prod => {
            const itemClone = itemTemplate.content.cloneNode(true);
            const itemDiv = itemClone.querySelector('.cart-item');
            
            itemDiv.dataset.id = prod.id;
            itemClone.querySelector('.item-img').src = `/public/imagenes/${prod.imagen}`;
            itemClone.querySelector('.item-img').alt = prod.titulo;
            itemClone.querySelector('.item-title').textContent = prod.titulo;
            itemClone.querySelector('.item-qty').textContent = prod.cantidad;
            itemClone.querySelector('.item-price').textContent = prod.precio_str;

            // Botón de eliminar
            itemClone.querySelector('.btn-remove-item').onclick = () => removeItem(prod.id);

            list.appendChild(itemClone);
          });

          summaryClone.getElementById('summary-items-count').textContent = `${data.total_items} artículo${data.total_items !== 1 ? 's' : ''}`;
          summaryClone.getElementById('summary-subtotal').textContent = data.subtotal;
          summaryClone.getElementById('summary-total').textContent = data.subtotal;

          cartContainer.appendChild(summaryClone);
          updateBadge(data.total_items);
        }
      } catch (error) {
        console.error('Error al cargar el carrito:', error);
        cartContainer.innerHTML = '<div class="alert alert-danger mx-3 mt-3">Error al conectar con la tienda.</div>';
      }
    }

    /**
     * Elimina un ítem mediante AJAX
     */
    async function removeItem(id) {
      try {
        const response = await fetch(`/api/carrito/${id}`, { method: 'DELETE' });
        const data = await response.json();
        if (data.success) {
          renderCart(); // Re-renderizar
        }
      } catch (error) {
        console.error('Error al eliminar ítem:', error);
      }
    }

    /**
     * Actualiza el contador (badge) del header
     */
    function updateBadge(total) {
      let badge = document.querySelector('.cart-badge');
      if (total > 0) {
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'cart-badge';
          cartIconLink.appendChild(badge);
        }
        badge.textContent = total;
      } else if (badge) {
        badge.remove();
      }
    }
  </script>
</body>
</html>
