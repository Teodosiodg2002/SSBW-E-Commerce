<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Tienda Prado{% endblock %}</title>
  <meta name="description" content="{% block description %}La tienda oficial del Museo del Prado{% endblock %}">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Georgia', serif; color: #333; background: #fff; }

    /* Barra superior */
    .top-bar { font-size: 0.75rem; letter-spacing: 0.08em; border-bottom: 1px solid #e0e0e0; padding: 6px 0; }
    .top-bar a { color: #555; text-decoration: none; }
    .top-bar a:hover { color: #000; }

    /* Header */
    .site-header { border-bottom: 1px solid #e0e0e0; padding: 18px 0 10px; }
    .site-logo { font-size: 1.9rem; font-weight: 700; letter-spacing: 0.18em; color: #000; text-decoration: none; }
    .site-logo:hover { color: #333; }
    .header-icons a { color: #555; font-size: 1.1rem; margin-left: 12px; text-decoration: none; }
    .header-icons a:hover { color: #000; }
    .lang-switcher { font-size: 0.8rem; color: #555; margin-left: 12px; }

    /* Search bar */
    .search-form .form-control {
      border-radius: 0; border: 1px solid #ccc; font-size: 0.85rem;
      padding: 5px 12px; background: #f9f9f9;
    }
    .search-form .btn { border-radius: 0; border: 1px solid #ccc; border-left: none; background: #f9f9f9; color: #555; }
    .search-form .btn:hover { background: #eee; }

    /* Navegación principal */
    .main-nav { border-bottom: 1px solid #e0e0e0; font-size: 0.78rem; letter-spacing: 0.1em; }
    .main-nav .nav-link { color: #555; padding: 10px 14px; text-transform: uppercase; }
    .main-nav .nav-link:hover, .main-nav .nav-link.active { color: #000; font-weight: 700; }

    /* Título de sección */
    .section-title { font-size: 1.5rem; letter-spacing: 0.2em; text-align: center; margin: 40px 0 30px; color: #222; text-transform: uppercase; }

    /* Tarjetas de producto */
    .product-card { border: none; background: transparent; transition: transform 0.2s; }
    .product-card:hover { transform: translateY(-3px); }
    .product-card .card-img-wrap {
      background: #f7f7f7; border: 1px solid #ebebeb;
      display: flex; align-items: center; justify-content: center;
      padding: 16px; height: 230px; overflow: hidden;
    }
    .product-card img { max-height: 200px; max-width: 100%; object-fit: contain; }
    .product-card .card-title { font-size: 0.9rem; color: #333; margin-top: 12px; text-align: center; line-height: 1.4; }
    .product-card .card-price { font-size: 0.95rem; color: #333; text-align: center; margin-top: 4px; }
    .product-card a { text-decoration: none; color: inherit; }

    /* Buscador con resultados */
    .search-results-info { font-size: 0.88rem; color: #666; margin-bottom: 20px; }

    /* Página de detalle */
    .detail-img-wrap {
      background: #f7f7f7; border: 1px solid #ebebeb;
      display: flex; align-items: center; justify-content: center;
      padding: 24px; min-height: 350px;
    }
    .detail-img-wrap img { max-width: 100%; max-height: 400px; object-fit: contain; }
    .detail-title { font-size: 1.6rem; font-weight: 600; margin-bottom: 16px; color: #222; }
    .detail-description { font-size: 0.95rem; color: #555; line-height: 1.7; white-space: pre-line; }
    .detail-price { font-size: 1.25rem; font-weight: 600; margin: 20px 0; color: #333; }
    .btn-add-cart {
      background-color: #666; color: #fff; border: none;
      padding: 10px 28px; letter-spacing: 0.1em; font-size: 0.85rem;
      border-radius: 0; text-transform: uppercase;
    }
    .btn-add-cart:hover { background-color: #444; color: #fff; }

    /* Footer */
    footer { border-top: 1px solid #e0e0e0; margin-top: 60px; padding: 30px 0; font-size: 0.8rem; color: #888; }
  </style>
</head>
<body>

  {# Barra superior #}
  <div class="top-bar">
    <div class="container d-flex justify-content-between">
      <a href="https://www.museodelprado.es" target="_blank" rel="noreferrer">MUSEO DEL PRADO</a>
      <a href="https://www.imagebankmuseodelprado.com/" target="_blank" rel="noreferrer">IMAGE BANK</a>
    </div>
  </div>

  {# Header principal #}
  <header class="site-header">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-3"></div>
        <div class="col-md-6 text-center">
          <a href="/" class="site-logo">TIENDA PRADO</a>
        </div>
        <div class="col-md-3 d-flex align-items-center justify-content-end">
          <form class="search-form d-flex" action="/buscar" method="get">
            <input class="form-control" type="search" name="busqueda" placeholder="Buscar..." value="{{ busqueda or '' }}" id="search-input">
            <button class="btn" type="submit"><i class="bi bi-search"></i></button>
          </form>
          <div class="header-icons d-none d-md-flex align-items-center">
            <a href="#" title="Mi cuenta"><i class="bi bi-person"></i></a>
            <a href="#" title="Cesta"><i class="bi bi-bag"></i></a>
          </div>
          <span class="lang-switcher">ES | EN</span>
        </div>
      </div>
    </div>
  </header>

  {# Navegación #}
  <nav class="main-nav">
    <div class="container">
      <ul class="nav d-flex flex-wrap">
        <li class="nav-item"><a class="nav-link" href="#">Libros</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Exposiciones</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Colaboraciones</a></li>
        <li class="nav-item"><a class="nav-link active" href="/">Impresiones</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Hogar</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Papelería</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Textil y Complementos</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Outlet</a></li>
      </ul>
    </div>
  </nav>

  {# Contenido de cada página #}
  <main class="container mt-4 mb-5">
    {% block content %}{% endblock %}
  </main>

  <footer>
    <div class="container text-center">
      <p>© Museo Nacional del Prado · Calle Ruiz de Alarcón 23, 28014 Madrid</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
