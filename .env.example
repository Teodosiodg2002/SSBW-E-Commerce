# .env.example — Variables de entorno necesarias para la aplicación
# Copia este archivo a .env y rellena los valores reales.
# ¡NUNCA subas .env a Git!

# ── Servidor ──────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=yo
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=ssbw

# ── Prisma (URL de conexión a la BD) ─────────────────────────────────
DATABASE_URL="postgresql://yo:cambia_esta_clave@localhost:5432/ssbw?schema=public"

# ── Autenticación JWT ─────────────────────────────────────────────────
# Usa un valor largo y aleatorio en producción: openssl rand -hex 32
SECRET_KEY="cambia-esta-clave-jwt"

# ── Sesiones (carrito) ────────────────────────────────────────────────
SESSION_SECRET="cambia-esta-clave-session"

# ── Logger ────────────────────────────────────────────────────────────
# Niveles disponibles: error | warn | info | debug
LOG_LEVEL=info
