---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Tienda Prado - Astro" } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen bg-base-200 font-montserrat">
		<header class="navbar bg-base-100 shadow-lg px-4 sm:px-8 sticky top-0 z-50">
			<div class="flex-1">
				<a href="/" class="text-xl font-bold text-primary">Tienda Prado 🏛️</a>
			</div>
			<nav class="flex-none">
				<ul class="menu menu-horizontal px-1 gap-2">
					<li><a href="/">Inicio</a></li>
					<li><a href="/carrousel">Galería</a></li>
					<li><a href="/ssg">Catálogo (SSG)</a></li>
				</ul>
			</nav>
		</header>

		<main class="container mx-auto p-4 sm:p-8">
			<slot />
		</main>

		<footer class="footer footer-center p-10 bg-base-100 text-base-content mt-auto">
			<aside>
				<p>© 2026 Tienda Prado - Construido con Astro + React</p>
			</aside>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-montserrat: 'Montserrat', sans-serif;
	}
</style>
