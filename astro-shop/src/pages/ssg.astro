---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Catálogo SSG - Tienda Prado Astro">
	<div class="hero min-h-[40vh] bg-base-100 rounded-3xl shadow-lg border border-base-300">
		<div class="hero-content text-center">
			<div class="max-w-md">
				<h1 class="text-4xl font-bold text-secondary">Static Site Generation</h1>
				<p class="py-6 text-base-content/80">
					Esta página es un placeholder para la <strong>Tarea 12</strong>. 
					Aquí implementaremos la generación estática de contenidos para un rendimiento imbatible.
				</p>
				<div class="badge badge-secondary badge-lg">Próximamente...</div>
			</div>
		</div>
	</div>
</Layout>
